# 企业微信配置
BOT_ID=你的机器人ID
SECRET=你的机器人密钥

# 和风天气API配置
HEFENG_API_KEY=你的和风天气API密钥
CITY_ID=城市ID（如101080101代表呼和浩特）
CITY_NAME=城市名称

# 定时推送配置
SCHEDULE_TIME=08:00
SCHEDULE_CHAT_ID=推送目标群聊ID
SCHEDULE_CHAT_TYPE=2

# LLM API 配置 (统一接口)
LLM_API_KEY=你的LLM API密钥
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-turbo
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1000
